rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // HELPERS GÉNÉRAUX
    // ═══════════════════════════════════════════════════════════════════════

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── NOTE SPARK PLAN (1.4) ──────────────────────────────────────────
    // Les Custom Claims (admin: true via Admin SDK) nécessitent le plan Blaze.
    // Sur Spark, l'accès admin est contrôlé côté client (router guard + email).
    // Les collections publiques sont protégées en écriture au niveau Firestore,
    // ce qui constitue la véritable barrière de sécurité des données publiques.
    // ────────────────────────────────────────────────────────────────────────

    // ═══════════════════════════════════════════════════════════════════════
    // HELPERS DE VALIDATION DE SCHÉMA (1.2)
    // ═══════════════════════════════════════════════════════════════════════

    // Taille maximale d'un champ Base64 image (~800 Ko en base64 ≈ 600 Ko fichier)
    // Firestore limite le document à 1 Mo — on laisse de la marge pour les autres champs.
    function isImageUrlSafe(data) {
      return !('imageUrl' in data)
          || data.imageUrl == ''
          || data.imageUrl.size() < 820000;
    }

    function isValidRecipe(data) {
      return data.keys().hasAll(['name', 'prepTime', 'mealType', 'category', 'allergenIds', 'suggestedSideIds', 'requiresFreeTime'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 200
          && data.prepTime is number
          && data.prepTime >= 0
          && data.prepTime <= 1440
          && data.mealType in ['Midi', 'Soir', 'Les Deux']
          && data.category in ['Pâtes', 'Viandes', 'Poissons', 'Soupes', 'Salades', 'Fast Food', 'Végétarien', 'Autre']
          && data.allergenIds is list
          && data.suggestedSideIds is list
          && data.requiresFreeTime is bool
          && isImageUrlSafe(data);
    }

    function isValidRecipeUpdate(data) {
      // Lors d'une mise à jour partielle, on vérifie uniquement les champs présents
      return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 200))
          && (!('prepTime' in data) || (data.prepTime is number && data.prepTime >= 0 && data.prepTime <= 1440))
          && (!('mealType' in data) || data.mealType in ['Midi', 'Soir', 'Les Deux'])
          && (!('category' in data) || data.category in ['Pâtes', 'Viandes', 'Poissons', 'Soupes', 'Salades', 'Fast Food', 'Végétarien', 'Autre'])
          && (!('allergenIds' in data) || data.allergenIds is list)
          && (!('suggestedSideIds' in data) || data.suggestedSideIds is list)
          && (!('requiresFreeTime' in data) || data.requiresFreeTime is bool)
          && isImageUrlSafe(data);
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['name', 'isActive', 'allergyIds'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.isActive is bool
          && data.allergyIds is list;
    }

    function isValidSimpleItem(data) {
      // Pour allergens, sideDishes : uniquement { name }
      return data.name is string
          && data.name.size() > 0
          && data.name.size() <= 200;
    }

    function isValidMeal(data) {
      return data.keys().hasAll(['date', 'type', 'status'])
          && data.date is string
          && data.date.size() > 0
          && data.type in ['Petit-déjeuner', 'Midi', 'Collation', 'Soir', 'Autre']
          && data.status in ['Prévu', 'Restaurant', 'Absent', 'Travail', 'Restes', 'Courses', 'Sauté'];
    }

    function isValidMealUpdate(data) {
      return (!('type' in data) || data.type in ['Petit-déjeuner', 'Midi', 'Collation', 'Soir', 'Autre'])
          && (!('status' in data) || data.status in ['Prévu', 'Restaurant', 'Absent', 'Travail', 'Restes', 'Courses', 'Sauté'])
          && (!('selectedSideDishIds' in data) || data.selectedSideDishIds is list)
          && (!('attendeeIds' in data) || data.attendeeIds is list);
    }

    function isValidShoppingItem(data) {
      return data.keys().hasAll(['name', 'checked', 'source'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 300
          && data.checked is bool
          && data.source in ['recipe', 'manual', 'pantry'];
    }

    function isValidShoppingItemUpdate(data) {
      return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 300))
          && (!('checked' in data) || data.checked is bool)
          && (!('customQuantity' in data) || (data.customQuantity is number && data.customQuantity >= 1 && data.customQuantity <= 99));
    }

    function isValidPantryItem(data) {
      return data.keys().hasAll(['name', 'selected'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 200
          && data.selected is bool;
    }

    function isValidPantryItemUpdate(data) {
      return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 200))
          && (!('selected' in data) || data.selected is bool);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // RÈGLE CATCH-ALL : tout est refusé par défaut
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ESPACE UTILISATEUR — isolation complète par UID
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId} {

      match /recipes/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidRecipe(request.resource.data);
        allow update: if isOwner(userId) && isValidRecipeUpdate(request.resource.data);
      }

      match /participants/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidParticipant(request.resource.data);
        allow update: if isOwner(userId)
            && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() > 0))
            && (!('isActive' in request.resource.data) || request.resource.data.isActive is bool)
            && (!('allergyIds' in request.resource.data) || request.resource.data.allergyIds is list);
      }

      match /allergens/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimpleItem(request.resource.data);
        allow update: if isOwner(userId) && isValidSimpleItem(request.resource.data);
      }

      match /sideDishes/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimpleItem(request.resource.data);
        allow update: if isOwner(userId) && isValidSimpleItem(request.resource.data);
      }

      match /meals/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMeal(request.resource.data);
        allow update: if isOwner(userId) && isValidMealUpdate(request.resource.data);
      }

      match /shoppingItems/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidShoppingItem(request.resource.data);
        allow update: if isOwner(userId) && isValidShoppingItemUpdate(request.resource.data);
      }

      match /pantryItems/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPantryItem(request.resource.data);
        allow update: if isOwner(userId) && isValidPantryItemUpdate(request.resource.data);
      }

      match /profile/data {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
            && request.resource.data.keys().hasAll(['isInitialized'])
            && request.resource.data.isInitialized is bool;
        allow delete: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLLECTIONS PUBLIQUES — lecture pour tout utilisateur authentifié
    // Écriture bloquée (seul le DataSeeder via Admin SDK peut écrire)
    // ═══════════════════════════════════════════════════════════════════════
    match /public_recipes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /public_allergens/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /public_sideDishes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isPayloadValid() {
      // Les règles de sécurité sont exécutées de manière stricte.
      // Firebase Firestore n'a pas de propriété native request.resource.size (c'est Storage qui a ça).
      // Nous nous fions donc à la taille max de Firestore (1MB) et aux validations de schéma.
      return true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Verrouillage de la base de données par défaut : tout est refusé
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Isolation multi-tenant : chaque utilisateur a les droits complets sur son espace personnel
    match /users/{userId} {
      
      // Modèle de base pour s'assurer que le champ vital 'name' est présent à la création
      match /recipes/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isPayloadValid() && request.resource.data.keys().hasAll(['name']);
        allow update: if isOwner(userId) && isPayloadValid();
      }
      
      match /participants/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isPayloadValid() && request.resource.data.keys().hasAll(['name']);
        allow update: if isOwner(userId) && isPayloadValid();
      }

      match /allergens/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isPayloadValid() && request.resource.data.keys().hasAll(['name']);
        allow update: if isOwner(userId) && isPayloadValid();
      }

      match /sideDishes/{docId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isPayloadValid() && request.resource.data.keys().hasAll(['name']);
        allow update: if isOwner(userId) && isPayloadValid();
      }
      
      match /meals/{docId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isPayloadValid();
      }
      
      match /profile/data {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isPayloadValid();
      }
    }
    
    // 2. Collections publiques (Données de base initiales clonées à la création du compte)
    match /public_recipes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /public_allergens/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /public_sideDishes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
